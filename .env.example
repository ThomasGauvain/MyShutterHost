# ================================
# MyShutterHost — Environment Variables
# ================================
# Copy this file to .env.local in each app and fill in real values.
# NEVER commit .env.local or any file with real secrets to git.

# ── DATABASE ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/myshutterhost"

# ── AUTH (Auth.js v5) ─────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# ── CLOUDFLARE R2 (Photo/Video Storage) ──────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME="myshutterhost-media"
CLOUDFLARE_R2_PUBLIC_URL="https://your-r2-public-url.r2.dev"

# ── STRIPE (Payments) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── RESEND (Email) ────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@myshutterhost.com"

# ── REDIS (Caching / Sessions) ────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── AI PROVIDERS (Optional — photographers bring their own keys) ───────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# ── EASYPOST (Shipping) ───────────────────────────────────────────────
EASYPOST_API_KEY=""

# ── FACE RECOGNITION (Optional — per photographer) ────────────────────
AWS_REKOGNITION_ACCESS_KEY=""
AWS_REKOGNITION_SECRET_KEY=""
AWS_REKOGNITION_REGION="us-east-1"

AZURE_FACE_API_KEY=""
AZURE_FACE_API_ENDPOINT=""

# ── APP URLS ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_MARKETING_URL="http://localhost:3001"

# ── MISC ──────────────────────────────────────────────────────────────
NODE_ENV="development"
