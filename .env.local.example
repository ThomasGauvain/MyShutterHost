# ================================
# LOCAL DEVELOPMENT OVERRIDES
# ================================
# Copy this file to .env.local (gitignored) and fill in your values.
# These are safe defaults for running locally with docker-compose.

# ── DATABASE (local Docker) ───────────────────────────────────────────
DATABASE_URL="postgresql://myshutterhost:localdevpassword@localhost:5432/myshutterhost"
POSTGRES_USER="myshutterhost"
POSTGRES_PASSWORD="localdevpassword"
POSTGRES_DB="myshutterhost"

# ── REDIS (local Docker) ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── pgAdmin (local Docker GUI) ────────────────────────────────────────
PGADMIN_EMAIL="admin@myshutterhost.local"
PGADMIN_PASSWORD="admin"

# ── AUTH ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-generate-a-real-secret-for-production"
NEXTAUTH_URL="http://localhost:3000"

# ── APP URLS (local) ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_PORTFOLIO_URL="http://localhost:3002"
NEXT_PUBLIC_MARKETING_URL="http://localhost:3001"

# ── STRIPE (use Stripe test keys locally) ─────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── CLOUDFLARE R2 ─────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME="myshutterhost-dev"
CLOUDFLARE_R2_PUBLIC_URL=""

# ── RESEND (email) ────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="dev@myshutterhost.local"

# ── NODE ──────────────────────────────────────────────────────────────
NODE_ENV="development"
